# Gmail IMAP
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Sender filter (default fallback in code: isbank)
ISBANK_EMAIL_FROM=isbank

# Exact sender address (recommended)
ISBANK_EMAIL_ADDRESS=bilgilendirme@ileti.isbank.com.tr

# One-off replay mode (optional)
ONE_OFF_REPLAY_ENABLED=false
ONE_OFF_REPLAY_DATE=06.03.2026
# Force replay even if UID was already processed (default: false)
ONE_OFF_REPLAY_FORCE=false
# Auto-disable one-off if target date is older than N days (default: 1)
ONE_OFF_REPLAY_MAX_AGE_DAYS=1

# Processed UID persistence (optional)
PROCESSED_IDS_FILE=processed-ids.json
PROCESSED_IDS_MAX=1000

# Green API
GREENAPI_INSTANCE=7105XXXX
GREENAPI_TOKEN=your_greenapi_token

# WhatsApp Group ID (example format)
WHATSAPP_GROUP_ID=120363XXXXXXX@g.us
